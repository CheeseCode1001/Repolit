# Copy to .env and fill in values for local development.
# On Windows PowerShell: Copy-Item .env.example .env

# --- Frontend (developer-painkiller) ---
BASE_PATH=/
PORT=5173
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Optional: Clerk proxy URL (production/Replit only)
# VITE_CLERK_PROXY_URL=http://localhost:5173/api/__clerk

# --- API server ---
API_PORT=8080
API_SERVER_URL=http://127.0.0.1:8080
APP_BASE_URL=http://localhost:5173

# Database — embedded PGlite works without installing PostgreSQL locally
DATABASE_URL=pglite://.local/repograph-pg
# Or use real PostgreSQL:
# DATABASE_URL=postgresql://postgres:repograph@localhost:5432/repograph

# Clerk
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# SESSION_SECRET=generate_a_long_random_string

# GitHub OAuth (register callback: http://localhost:5173/api/github/oauth/callback)
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# --- Gemini AI (repo analysis) ---
# AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key
# AI_INTEGRATIONS_GEMINI_BASE_URL=http://localhost:1106/modelfarm/gemini
